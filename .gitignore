# is commented out by default.
#.vscode/

# Kotlin
.kotlin/

# Web related
lib/generated_plugin_registrant.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Gradle related
.gradle/
build/
*/build/
local.properties

# API keys for transcription providers (Deepgram/Soniox) — never commit.
# Copy secrets.properties.example → secrets.properties and fill in.
secrets.properties

# Local scratch dumps from `gh api` / PR tooling — never commit.
/pr.txt
/pr.json
/pr_body.md
/pr_diff.txt
/pr_*.json
/comments.json
/reviews.json
/issues_comments.json

# Android Studio
captures/
.externalNativeBuild
.cxx

# iOS — the Xcode project is generated from iosApp/project.yml via xcodegen.
# Only the source (Swift), the project spec, and the generated Info.plist
# are committed; the .xcodeproj itself is regenerable.
iosApp/ICSApp.xcodeproj/
iosApp/ICSApp.xcworkspace/

# Exceptions to above rules.
!/packages/flutter_tools/test/data/dart_dependencies_test/**/.packages
